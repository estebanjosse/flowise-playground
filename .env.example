# FlowiseAI Configuration
# Copy this file to .env and customize as needed

# ============================================
# Flowise Settings
# ============================================

# Port to expose Flowise UI (default: 3000)
FLOWISE_PORT=3000

# Optional: Set username and password to enable authentication
# Leave empty to disable authentication
FLOWISE_USERNAME=
FLOWISE_PASSWORD=

# Log level: error, warn, info, verbose, debug (default: info)
LOG_LEVEL=info

# ============================================
# Qdrant Settings (Optional Vector Database)
# ============================================

# Port to expose Qdrant REST API (default: 6333)
QDRANT_PORT=6333

# Port to expose Qdrant gRPC API (default: 6334)
QDRANT_GRPC_PORT=6334
