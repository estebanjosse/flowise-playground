# FlowiseAI Configuration
# Copy this file to .env and customize as needed

# ============================================
# Flowise Settings
# ============================================

# Port to expose Flowise UI (default: 3000)
FLOWISE_PORT=3000

# Log level: error, warn, info, verbose, debug (default: info)
LOG_LEVEL=info

# ============================================
# Qdrant Settings (Optional Vector Database)
# ============================================

# Port to expose Qdrant REST API (default: 6333)
QDRANT_PORT=6333

# Port to expose Qdrant gRPC API (default: 6334)
QDRANT_GRPC_PORT=6334

# ============================================
# Ollama Settings (Optional Local LLMs)
# See library for available models: https://ollama.com/library
# ============================================
# Comma-separated list of Ollama models to auto-pull on startup (default: qwen2.5:0.5b)
OLLAMA_AUTO_PULL_MODELS=qwen2.5:0.5b